{
  "name": "@mantine-vue/dates",
  "version": "2.0.1",
  "description": "Vue date and time picker components equivalent to @mantine/dates",
  "license": "MIT",
  "files": [
    "cjs",
    "esm",
    "lib",
    "styles.css",
    "styles.layer.css",
    "styles"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    },
    "./styles.css": "./styles.css",
    "./styles.layer.css": "./styles.layer.css"
  },
  "devDependencies": {
    "@mantine-vue/core": "workspace:*",
    "@mantine-vue/hooks": "workspace:*",
    "@vue/compiler-dom": "^3.5.0",
    "@vue/test-utils": "^2.4.6",
    "dayjs": "^1.11.21",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "@mantine-vue/core": "2.0.1",
    "@mantine-vue/hooks": "2.0.1",
    "dayjs": ">=1.0.0",
    "vue": "^3.5.0"
  }
}
