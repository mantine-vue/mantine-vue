{
  "name": "@mantine-vue/store",
  "version": "0.0.0",
  "description": "External store primitive for later extension packages",
  "license": "MIT",
  "sideEffects": false,
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    }
  },
  "devDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
