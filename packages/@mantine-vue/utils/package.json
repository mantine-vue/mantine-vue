{
  "name": "@mantine-vue/utils",
  "version": "2.2.1",
  "description": "Framework-independent utilities ported from Mantine foundation",
  "license": "MIT",
  "files": [
    "cjs",
    "esm",
    "lib",
    "styles.css",
    "styles.layer.css",
    "styles"
  ],
  "sideEffects": false,
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    }
  }
}
