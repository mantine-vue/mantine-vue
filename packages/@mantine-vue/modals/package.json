{
  "name": "@mantine-vue/modals",
  "version": "1.1.2",
  "description": "Vue modals management system equivalent to @mantine/modals",
  "license": "MIT",
  "files": [
    "cjs",
    "esm",
    "lib",
    "styles.css",
    "styles.layer.css",
    "styles"
  ],
  "sideEffects": false,
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    }
  },
  "devDependencies": {
    "@mantine-vue/core": "workspace:*",
    "@mantine-vue/store": "workspace:*",
    "@vue/compiler-dom": "^3.5.0",
    "@vue/test-utils": "^2.4.6",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "@mantine-vue/core": "1.1.2",
    "@mantine-vue/store": "1.1.2",
    "vue": "^3.5.0"
  }
}
