{
  "name": "@mantine-vue/carousel",
  "version": "2.2.0",
  "description": "Embla based carousel, Vue equivalent to @mantine/carousel",
  "license": "MIT",
  "files": [
    "cjs",
    "esm",
    "lib",
    "styles.css",
    "styles.layer.css",
    "styles"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./cjs/index.cjs",
  "module": "./esm/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./esm/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./cjs/index.cjs"
      }
    }
  },
  "devDependencies": {
    "@mantine-vue/core": "workspace:*",
    "@mantine-vue/hooks": "workspace:*",
    "@vue/compiler-dom": "^3.5.0",
    "@vue/test-utils": "^2.4.6",
    "embla-carousel": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "@mantine-vue/core": "2.2.0",
    "@mantine-vue/hooks": "2.2.0",
    "embla-carousel": ">=8.0.0",
    "embla-carousel-vue": ">=8.0.0",
    "vue": "^3.5.0"
  }
}
