  "installCommand": "corepack enable && yarn install --immutable",
  "buildCommand": "yarn docs:build",
  "outputDirectory": "apps/mantine.dev/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
